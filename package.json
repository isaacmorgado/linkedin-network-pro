    "@datastructures-js/priority-queue": "^6.3.5",
    "dexie": "^4.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.4.13",
    "@floating-ui/react": "^0.26.24",
    "zustand": "^5.0.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.454.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "date-fns": "^4.1.0",
    "chromadb": "^1.9.2",
    "compromise": "^14.14.3",
